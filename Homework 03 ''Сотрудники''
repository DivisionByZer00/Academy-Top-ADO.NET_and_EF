using System;
using System.IO;
using Microsoft.Data.Sqlite;

namespace HelloWorldSample
{
    class Program
    {
        static void Main()
        {


            File.Delete("hello.db");


            CreateAndSeed();
            Query();

            

        }

        static void CreateAndSeed()
        {
            using var connection = new SqliteConnection("Data Source=hello.db");

            connection.Open();

            var command = connection.CreateCommand();
            command.CommandText = """
                CREATE TABLE Сотрудники (
                    ID INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
                    ФИО TEXT NOT NULL,
                    Дата_рождения TEXT NOT NULL
                );
 
                INSERT INTO Сотрудники (ФИО, Дата_рождения)
                VALUES ('Иванов Иван Иванович', '1985-04-12'),
                       ('Петров Петр Петрович', '1990-08-23'),
                       ('Сидорова Анна Сергеевна', '1992-11-05'),
                       ('Смирнов Алексей Викторович', '1988-02-28'),
                       ('Кузнецова Мария Александровна', '1995-09-14');
            """;
            command.ExecuteNonQuery();

            
        }

        static void Query()
        {
            using var connection = new SqliteConnection("Data Source=hello.db");

            connection.Open();

            using var command = connection.CreateCommand();
            command.CommandText = """
                SELECT ID, ФИО, Дата_рождения
                FROM Сотрудники
            """;

            using var reader = command.ExecuteReader();

            while (reader.Read())
            {
                var id = reader.GetInt32(0);
                var name = reader.GetString(1);
                var birthDate = reader.GetString(2);

                Console.WriteLine($"ID: {id}  ФИО: {name}  Дата рождения: {birthDate}");
            }
        }
    }
}
